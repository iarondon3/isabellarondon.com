---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = "Isabella Rondon is a freelance data analyst helping early-stage startups build data pipelines, dashboards, and AI automation.",
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://isabellarondon.com/og-image.svg" />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:type" content="website" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://isabellarondon.com/og-image.svg" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="generator" content={Astro.generator} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <title>{title}</title>

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-SX06HT75KK"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-SX06HT75KK');
  </script>

  <!-- Microsoft Clarity -->
  <script type="text/javascript">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "x22tqfo0eu");
  </script>
</head>
<body>

  <nav>
    <a href="/" class="nav-logo">Isabella Rondon<span>.</span></a>
    <ul class="nav-links">
      <li><a href="/services">Services</a></li>
      <li><a href="/case-studies">Case Studies</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/contact" class="nav-cta">Book a Call</a></li>
    </ul>
  </nav>

  <slot />

  <footer>
    <a href="/" class="footer-logo">Isabella Rondon<span>.</span></a>
    <ul class="footer-links">
      <li><a href="/services">Services</a></li>
      <li><a href="/case-studies">Case Studies</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/contact">Contact</a></li>
    </ul>
    <span class="footer-copy">© 2026 Isabella Rondon</span>
  </footer>

</body>
</html>