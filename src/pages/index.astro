---
import Layout from '../layouts/Layout.astro';

const stackItems = [
  { icon: 'https://cdn.simpleicons.org/python',         label: 'Python' },
  { icon: 'https://cdn.simpleicons.org/postgresql',     label: 'PostgreSQL' },
  { icon: 'https://cdn.simpleicons.org/mysql',          label: 'MySQL' },
  { icon: 'https://cdn.simpleicons.org/googlecloud',    label: 'GCP' },
  { icon: 'https://cdn.simpleicons.org/googlebigquery', label: 'BigQuery' },
  { icon: 'https://cdn.simpleicons.org/googlesheets',   label: 'Google Sheets' },
  { icon: 'https://api.iconify.design/simple-icons:powerbi.svg', label: 'Power BI' },
  { icon: 'https://api.iconify.design/simple-icons:tableau.svg', label: 'Tableau' },
  { icon: 'https://cdn.simpleicons.org/looker',         label: 'Looker' },
  { icon: 'https://cdn.simpleicons.org/n8n',            label: 'n8n' },
  { icon: 'https://api.iconify.design/simple-icons:openai.svg',  label: 'OpenAI' },
  { icon: 'https://cdn.simpleicons.org/anthropic',      label: 'Anthropic' },
];
---

<Layout
  title="Freelance Data Analyst for Startups | Isabella Rondon"
  description="Isabella Rondon is a freelance data analyst helping early-stage startups build data pipelines, dashboards, and AI automation. Based in the US."
>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-badge">For Seed &amp; Series A Startups</div>
      <div class="hero-eyebrow">
        Your startup is drowning in data and starving for insights.
      </div>
      <h1 class="hero-headline">
        Turn your data into<br>
        decisions <span class="accent-light">that scale.</span>
      </h1>
      <p class="hero-subheadline">
        I'm a freelance data analyst for early-stage startups. I build the data
        foundations founders actually need — automated pipelines, financial
        dashboards, and AI-powered automation. Backed by 5 years driving data
        strategy at a B2B financial services company.
      </p>
      <div class="hero-ctas">
        <a href="https://cal.com/isabella-rondon-jrkvbh/30min" class="btn-primary" target="_blank" rel="noopener">
          Book a Discovery Call &nbsp;→
        </a>
        <a href="/case-studies" class="btn-secondary">See My Work &nbsp;→</a>
      </div>
    </div>
  </section>

  <!-- STACK STRIP -->
  <div class="stack-strip">
    <div class="stack-track">
      {[...stackItems, ...stackItems].map(({ icon, label }) => (
        <div class="stack-item">
          <img src={icon} alt="" width="36" height="36" />
          <span>{label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- SERVICES -->
  <section class="services" id="services">
    <div class="section-label">Services</div>
    <h2 class="section-title">Data Services for Early-Stage Startups</h2>
    <p class="section-intro">
      Productized services with fixed scope and defined deliverables —
      clear output, clear timeline.
    </p>

    <div class="services-grid">

      <div class="service-card">
        <div class="service-number">01</div>
        <div class="service-name">Data Audit</div>
        <div class="service-tagline">The fastest way to know where your data stands.</div>
        <ul class="service-bullets">
          <li>Full review of your data sources, pipelines, and reporting</li>
          <li>Identification of revenue leaks and unused data</li>
          <li>Prioritized roadmap of what to fix first and why</li>
        </ul>
        <div class="service-footer">
          <a href="https://cal.com/isabella-rondon-jrkvbh/30min" class="service-link" target="_blank" rel="noopener">Book a call →</a>
        </div>
      </div>

      <div class="service-card">
        <div class="service-number">02</div>
        <div class="service-name">Dashboard Sprint</div>
        <div class="service-tagline">From raw data to decisions — in two weeks.</div>
        <ul class="service-bullets">
          <li>Data cleaning pipeline for reliable, structured data</li>
          <li>KPI definition aligned with your business goals</li>
          <li>Dashboard in Power BI, Tableau, or Looker — auto-updated</li>
        </ul>
        <div class="service-footer">
          <a href="https://cal.com/isabella-rondon-jrkvbh/30min" class="service-link" target="_blank" rel="noopener">Book a call →</a>
        </div>
      </div>

      <div class="service-card">
        <div class="service-number">03</div>
        <div class="service-name">ETL Pipeline &amp; Automation</div>
        <div class="service-tagline">Stop doing manually what a pipeline can do for you.</div>
        <ul class="service-bullets">
          <li>Custom pipeline design and architecture on GCP</li>
          <li>REST API integrations with your existing tools</li>
          <li>Automated runs, error handling, and full documentation</li>
        </ul>
        <div class="service-footer">
          <a href="https://cal.com/isabella-rondon-jrkvbh/30min" class="service-link" target="_blank" rel="noopener">Book a call →</a>
        </div>
      </div>

      <div class="service-card">
        <div class="service-number">04</div>
        <div class="service-name">Fractional Data Analyst</div>
        <div class="service-tagline">Senior data expertise, without the full-time hire.</div>
        <ul class="service-bullets">
          <li>Ongoing dashboards, reporting, and analysis</li>
          <li>Data strategy aligned with your growth stage</li>
          <li>Direct access — no account managers, no middlemen</li>
        </ul>
        <div class="service-footer">
          <a href="https://cal.com/isabella-rondon-jrkvbh/30min" class="service-link" target="_blank" rel="noopener">Book a call →</a>
        </div>
      </div>

      <div class="service-card">
        <div class="service-number">05</div>
        <div class="service-name">AI Agent Development</div>
        <div class="service-tagline">Automate sales, support, or operations with a custom AI agent.</div>
        <ul class="service-bullets">
          <li>Custom agent built on your business rules, not a template</li>
          <li>Integrations with your existing CRM, calendar, and tools</li>
          <li>Silent lead qualification and conversation data capture</li>
        </ul>
        <div class="service-footer">
          <a href="https://cal.com/isabella-rondon-jrkvbh/30min" class="service-link" target="_blank" rel="noopener">Book a call →</a>
        </div>
      </div>

      <div class="service-card service-card-custom">
        <div class="service-custom-left">
          <div class="service-name">Not seeing exactly what you need?</div>
          <div class="service-tagline">Every data problem is different. Let's talk about yours.</div>
        </div>
        <div class="service-custom-right">
          <a href="https://cal.com/isabella-rondon-jrkvbh/30min" class="btn-primary" target="_blank" rel="noopener">
            Book a Discovery Call &nbsp;→
          </a>
          <span style="font-size:12px;color:var(--text-muted)">No commitment. 30 minutes.</span>
        </div>
      </div>

    </div>
  </section>

  <!-- CASE STUDIES -->
  <section class="case-studies" id="case-studies">
    <div class="case-studies-header">
      <div class="case-studies-header-left">
        <div class="section-label">Case Studies</div>
        <h2 class="section-title">Real Projects. Real Results.</h2>
      </div>
      <a href="/case-studies" class="view-all">View all case studies &nbsp;→</a>
    </div>

    <div class="cs-grid">
      <a href="/case-studies/financial-reporting-automation" class="cs-card">
        <div class="cs-service-tag">ETL Pipeline &amp; Automation</div>
        <div class="cs-headline">
          2 days of manual QuickBooks work every week. Now a pipeline runs it daily — for 8 companies at once.
        </div>
        <div class="cs-stat">
          <div class="cs-stat-value">16 hrs<span style="font-size:16px;font-weight:500;color:var(--text-muted)">/week</span></div>
          <div class="cs-stat-label">recovered for the finance team</div>
        </div>
        <div class="cs-link">Read case study →</div>
      </a>

      <a href="/case-studies/financial-data-strategy" class="cs-card">
        <div class="cs-service-tag">Data Strategy · Workflow Automation</div>
        <div class="cs-headline">
          Days of reconciliation. Departments working from different numbers. I built the infrastructure that replaced all of it.
        </div>
        <div class="cs-stat">
          <div class="cs-stat-value">Days → &lt;1hr</div>
          <div class="cs-stat-label">reconciliation time</div>
        </div>
        <div class="cs-link">Read case study →</div>
      </a>

      <a href="/case-studies/ai-sales-agent-car-dealership" class="cs-card">
        <div class="cs-service-tag">AI Agent Development</div>
        <div class="cs-headline">
          Most people talk about what an AI agent could do. Here's one you can actually talk to.
        </div>
        <div class="cs-stat">
          <div class="cs-stat-value">24/7</div>
          <div class="cs-stat-label">availability · 0 hallucinations in testing</div>
        </div>
        <div class="cs-link">Read case study →</div>
      </a>
    </div>
  </section>

  <!-- CTA FINAL -->
  <div class="cta-final">
    <div class="cta-final-left">
      <div class="cta-final-label">Ready to build?</div>
      <h2 class="cta-final-headline">
        Your startup needs a data foundation.<br>Let's build it right.
      </h2>
      <p class="cta-final-sub">
        Book a 30-minute discovery call. We'll figure out exactly what you need —
        and whether I'm the right person to build it.
      </p>
    </div>
    <div class="cta-final-right">
      <a href="https://cal.com/isabella-rondon-jrkvbh/30min" class="btn-primary" target="_blank" rel="noopener">
        Book a Discovery Call &nbsp;→
      </a>
      <span class="cta-note">No commitment. 30 minutes.</span>
    </div>
  </div>

</Layout>
